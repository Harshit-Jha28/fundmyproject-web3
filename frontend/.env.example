# EduFundX Frontend Environment Variables

# Soroban Network Configuration
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Contract Addresses (deploy contracts first, then fill these in)
NEXT_PUBLIC_CORE_CONTRACT_ID=
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=
NEXT_PUBLIC_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_MILESTONE_CONTRACT_ID=
NEXT_PUBLIC_NATIVE_TOKEN_CONTRACT_ID=

# Stellar Horizon (for account queries)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Explorer
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet

# App
NEXT_PUBLIC_APP_NAME=EduFundX
NEXT_PUBLIC_APP_VERSION=1.0.0
