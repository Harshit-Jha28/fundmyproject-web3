# ==================================
# EduFundX Environment Configuration
# ==================================

# Stellar Network
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract Addresses (populated after deployment)
NEXT_PUBLIC_CORE_CONTRACT_ID=
NEXT_PUBLIC_REPUTATION_CONTRACT_ID=
NEXT_PUBLIC_NATIVE_TOKEN_CONTRACT_ID=

# Deployer Account (DO NOT COMMIT real secrets)
STELLAR_DEPLOYER_SECRET=
STELLAR_DEPLOYER_PUBLIC=

# Admin Account
STELLAR_ADMIN_SECRET=
STELLAR_ADMIN_PUBLIC=

# Frontend
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet
NEXT_PUBLIC_PLATFORM_FEE_BPS=250

# Observability (optional)
NEXT_PUBLIC_ENABLE_LOGGING=true
SENTRY_DSN=
